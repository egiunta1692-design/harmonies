# Copia questo file in .env e riempi con i valori del tuo progetto Supabase
# (Project Settings -> API nella dashboard Supabase)

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJI...

# Facoltativa. Se "true", sblocca (a livello di codice) l'interruttore
# "anteprima live" nella schermata di gioco: ogni giocatore può poi
# scegliere per sé se attivarla (spenta di default anche quando
# sbloccata). Se assente o "false" (default), l'interruttore non
# compare affatto e l'anteprima live resta sempre disattivata per
# tutti — utile per risparmiare scritture extra al database durante i
# test, senza dover toccare il codice ogni volta.
VITE_ENABLE_LIVE_PREVIEW=false
